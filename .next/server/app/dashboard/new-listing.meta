{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/new-listing/layout,_N_T_/dashboard/new-listing/page,_N_T_/dashboard/new-listing"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/new-listing/__PAGE__",
    "/dashboard/new-listing",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}